<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Plugin.Firebase.Core</id>
    <version>4.0.0</version>
    <title>Plugin.Firebase</title>
    <authors>Tobias Buchholz</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <projectUrl>https://github.com/TobiasBuchholz/Plugin.Firebase</projectUrl>
    <description>The plugin includes cross-platform APIs for Firebase Core.</description>
    <copyright>Copyright 2023</copyright>
    <tags>xamarin, ios, android</tags>
    <repository type="git" url="https://github.com/TobiasBuchholz/Plugin.Firebase" commit="243d8e5fa92da6f33ca449ff2e0aea0150fe9bd6" />
    <dependencies>
      <group targetFramework="net9.0" />
      <group targetFramework="net9.0-android35.0">
        <dependency id="GoogleGson" version="2.11.0.3" exclude="Build,Analyzers" />
        <dependency id="Xamarin.Firebase.Common" version="121.0.0.6" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0-ios18.0">
        <dependency id="AdamE.Firebase.iOS.Core" version="12.5.0.4" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>